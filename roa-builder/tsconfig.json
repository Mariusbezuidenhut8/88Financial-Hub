{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "noEmit":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "baseUrl":          ".",
    "paths": {
      "@88fh/master-data-model":      ["../master-data-model/src/index.ts"],
      "@88fh/financial-health-score": ["../financial-health-score/src/index.ts"]
    }
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules"]
}
